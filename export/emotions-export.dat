/*Menü Farben*/

.menu-item-inner {
  color: #ffffff; !important;
}

@media (min-width: 1200px) {
  .button-menu {
    display: none !important;
  }
}

.button-menu {
  color: #ffffff;
  padding: 12px 24px;
  border-radius: 999px;         
  border: none;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.25s ease;
}

.menu-light:not(.custom-menu-open):not(.menu-dark) {
  --foreground-color: #ff4b06 !important;
}

/*Menü Button*/

/* MOBILE MENU BUTTON — HARD OVERRIDE (scope as much as possible) */
button.hamburger-link.button-menu.button,
button.hamburger-link.button-menu.button:hover,
button.hamburger-link.button-menu.button:focus,
button.hamburger-link.button-menu.button:active {
  background: #ff5a00 !important;
  background-image: none !important;
  color: #fff !important;

  opacity: 1 !important;
  filter: none !important;
  mix-blend-mode: normal !important;

  border: 0 !important;
  box-shadow: none !important;
  text-shadow: none !important;

  width: 44px !important;
  height: 44px !important;
  padding: 0 !important;

  display: flex !important;
  align-items: center !important;
  justify-content: center !important;

  border-radius: 999px !important;
  line-height: 1 !important;
  font-size: 0 !important; /* kills text-based icon alignment issues */
  transform: none !important;
}

button.hamburger-link.button-menu.button::before {
  content: "";
  width: 18px !important;
  height: 12px !important;
  display: block;

  background:
    linear-gradient(
      to bottom,
      #fff 0 2px,
      transparent 2px 5px,
      #fff 5px 7px,
      transparent 7px 10px,
      #fff 10px 12px
    ) !important;
}

/* Put the mobile header / menu toggle ABOVE hero overlays */
header,
.site-header,
.elementor-location-header,
.elementor-element.elementor-sticky,
.elementor-section,
.elementor-container {
  position: relative;
}

button.hamburger-link.button-menu.button {
  position: relative !important;
  z-index: 999999 !important;
}

/* If the button sits inside a wrapper link/div, lift that too */
button.hamburger-link.button-menu.button,
button.hamburger-link.button-menu.button * ,
button.hamburger-link.button-menu.button::before {
  position: relative;
  z-index: 999999 !important;
}


/*Kontakt Formular Text Farben*/

.menu-light, .panel-font-light, .wolf-core-font-light  {
 --foreground-color: #ffffff; !important
} 

/*Kontakt Formular Linie Farben*/

.wp-block-search .wp-block-search__input, .wpcf7-form-control-wrap
input[type=checkbox], input[type=color], input[type=date], input[type=datetime-local], input[type=datetime], input[type=email], input[type=month], input[type=number], input[type=password], input[type=search], input[type=tel], input[type=text], input[type=time], input[type=url], input[type=week], select, textarea {
background-color: transparent!important;
border: var(--border-width) solid;
border-color: #FF4B06!important;
border-radius: 0;
box-shadow: none!important;
color: inherit!important; }

/*Footer Links*/

.elementor-widget-text-editor a:not(.no-link-style), .link, .link-list a .elementor-icon-list-text, p:not(.attachment)>a:not(.tag-cloud-link):not(.no-link-style):not(.button):not(.theme-button-text):not(.theme-button-text-accent):not(.theme-button-secondary):not(.theme-button-special):not(.theme-button-primary):not(input[type=submit]):not(.button-download):not(.added_to_cart):not(.button-secondary):not(.menu-link):not(.filter-link):not(.entry-link):not(.more-link):not(.wvc-image-inner):not(.wvc-button):not(.wvc-bigtext-link):not(.wvc-fittext-link):not(.ui-tabs-anchor):not(.wvc-icon-title-link):not(.wvc-icon-link):not(.wvc-social-icon-link):not(.wvc-team-member-social):not(.wolf-tweet-link):not(.author-link) {
border: 0!important;
color: #FFFFFF!important;
font-weight: 700;
padding: 0 1px;
position: relative;
transition: color .3s ease;
white-space: nowrap;
z-index: 0;
}

/*Footer Display Custom Footer*/

.elementor-6149 {
  display: none !important;
}

/* Keep your injected Elementor footer visible */
.custom-footer-wrap {
  display: block !important;
}

/* Button Newsletter */

.wolf-core-mailchimp-submit svg path {
fill: #ffffff!important;
}

